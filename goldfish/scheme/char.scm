       ((#\9 #\x4E5D #\x7396 #\xAD6C #\x200E9) 9)
       ;; 9 九 玖 구 𠃩
       (else #f)
      ) ;case
    ) ;define

    (define (char-upcase char)
      (unless (char? char)
        (error 'type-error "char-upcase: parameter must be character")
      ) ;unless
      (let ((cp (char->integer char)))
        (let ((result (hash-table-ref *char-upcase-ht* cp)))
          (if result (integer->char result) char)
        ) ;let
      ) ;let
    ) ;define

    (define (char-downcase char)
      (unless (char? char)
        (error 'type-error "char-downcase: parameter must be character")
      ) ;unless
      (let ((cp (char->integer char)))
        (let ((result (hash-table-ref *char-downcase-ht* cp)))
          (if result (integer->char result) char)
        ) ;let
      ) ;let
    ) ;define

    (define (char-foldcase char)
