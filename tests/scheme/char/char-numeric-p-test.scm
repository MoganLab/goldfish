(import (liii check) (scheme char))
(check-set-mode! 'report-failed)

;; char-numeric?
;; 判断字符是否为数字。
;;
;; 语法
;; ----
;; (char-numeric? char) → boolean?
;;
;; 参数
;; ----
;; char : character
;; 要判断的字符
;;
;; 返回值
;; ------
;; boolean?
;; 如果字符是数字则返回 #t，否则返回 #f
;;
;; 注意
;; ----
;; - 对于 ASCII 数字字符 #\0 到 #\9，返回 #t
;; - 对于大量 Unicode 数字字符（如阿拉伯数字、梵文数字、上标、分数、全角数字、数学字母数字等），返回 #t
;; - 当前实现基于 Chez Scheme 10.3 的 char-numeric? 行为，覆盖 1919 个 Unicode 字符
;; - 对于非数字字符，返回 #f
;; - 遵循 R7RS 标准规范
;;
;; 错误处理
;; ------
;; type-error
;; 参数必须是字符类型，否则会抛出异常

;; ASCII 数字测试
(check (char-numeric? #\x30) => #t)
(check (char-numeric? #\x31) => #t)
(check (char-numeric? #\x32) => #t)
(check (char-numeric? #\x33) => #t)
(check (char-numeric? #\x34) => #t)
(check (char-numeric? #\x35) => #t)
(check (char-numeric? #\x36) => #t)
(check (char-numeric? #\x37) => #t)
(check (char-numeric? #\x38) => #t)
(check (char-numeric? #\x39) => #t)

